{
    "$schema": "https://raw.githubusercontent.com/aspect-dev/asconfig/main/asconfig.schema.json",
    "targets": {
        "vault": {
            "outFile": "build/RevenueVault.wasm",
            "textFile": "build/RevenueVault.wat",
            "use": ["abort=src/index/abort"]
        },
        "feerouter": {
            "outFile": "build/FeeRouter.wasm",
            "textFile": "build/FeeRouter.wat",
            "use": ["abort=src/feerouter-index/abort"]
        }
    },
    "options": {
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "exportStart": "start",
        "transform": "@btc-vision/opnet-transform"
    }
}
